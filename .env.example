# =============================================================================
# Media Data Platform — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values.
# .env is never committed to git.

# -----------------------------------------------------------------------------
# GCP
# -----------------------------------------------------------------------------
GCP_PROJECT_ID=media-data-platform

# Path to the GCP service account JSON key
# Create one at: GCP Console → IAM → Service Accounts → Keys
GOOGLE_APPLICATION_CREDENTIALS=/path/to/gcp-key.json

# -----------------------------------------------------------------------------
# Meta Ads API
# -----------------------------------------------------------------------------
# Create an app at: https://developers.facebook.com
META_ADS_APP_ID=your_app_id
META_ADS_APP_SECRET=your_app_secret
META_ADS_ACCESS_TOKEN=your_access_token
# Format: act_XXXXXXXXX
META_ADS_ACCOUNT_ID=act_your_account_id
